{
  "name": "iu-site",
  "version": "1.0.0",
  "description": "Infinite Union website",
  "scripts": {
    "lint:html": "html-validate index.html services/constructor.html services/websites.html services/privacy.html",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:js": "eslint index.html services/*.html",
    "lint": "npm run lint:html && npm run lint:js",
    "lhci": "lhci autorun",
    "start": "npx serve . -p $PORT"
  },
  "devDependencies": {
    "@html-eslint/eslint-plugin": "^0.63.0",
    "@html-eslint/parser": "^0.63.0",
    "@lhci/cli": "^0.14.0",
    "eslint": "^10.6.0",
    "html-validate": "^8.7.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "type": "module",
  "dependencies": {
    "serve": "^14.2.0"
  }
}
