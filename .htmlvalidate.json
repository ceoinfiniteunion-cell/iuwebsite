{
  "extends": [
    "html-validate:recommended"
  ],
  "rules": {
    "no-inline-style": "off",
    "long-title": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off",
    "attribute-boolean-style": "off",
    "allowed-links": "off",
    "no-unknown-elements": "off",
    "attribute-allowed-values": "off",
    "no-experimental-attributes": "off",
    "meta-refresh": "off"
  },
  "elements": [
    "html5"
  ]
}
